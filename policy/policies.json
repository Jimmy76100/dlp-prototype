{
  "version": "1.0",
  "policies": [
    {
      "id": "policy-001",
      "name": "Block credit cards in uploads",
      "description": "Block HTTP uploads containing credit card numbers.",
      "enabled": true,
      "scope": { "channels": ["http_upload", "smtp"], "users": ["*"], "hosts": ["*"] },
      "conditions": {
        "content": {
          "regex_any": ["CREDIT_CARD_LUHN"],
          "min_matches": 1
        },
        "metadata": {}
      },
      "action": {
        "type": "block",
        "params": { "quarantine_path": "/var/dlp/quarantine", "notify_admin": true }
      },
      "severity": "high",
      "created_by": "admin",
      "created_at": "2025-11-11T00:00:00Z"
    },
    {
      "id": "policy-002",
      "name": "Alert API keys on clipboard",
      "description": "Alert (but allow) when clipboard contains likely API keys.",
      "enabled": true,
      "scope": { "channels": ["clipboard"], "users": ["*"] },
      "conditions": {
        "content": {
          "regex_any": ["API_KEY_PATTERN"],
          "min_matches": 1
        }
      },
      "action": {
        "type": "alert",
        "params": { "notify_email": ["secops@example.com"] }
      },
      "severity": "medium"
    }
  ],
  "regex_definitions": {
    "CREDIT_CARD_LUHN": "\\b(?:4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13}|6(?:011|5[0-9]{2})[0-9]{12})\\b",
    "API_KEY_PATTERN": "\\b[A-Za-z0-9_\\-]{20,50}\\b"
  }
}
